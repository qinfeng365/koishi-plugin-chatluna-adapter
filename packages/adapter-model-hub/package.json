{
    "name": "koishi-plugin-chatluna-model-hub-adapter",
    "description": "Multi-provider OpenAI-compatible model hub adapter for ChatLuna",
    "version": "1.2.3",
    "homepage": "https://github.com/qinfeng365/koishi-plugin-chatluna-adapter/tree/main/packages/adapter-model-hub#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/qinfeng365/koishi-plugin-chatluna-adapter.git",
        "directory": "packages/adapter-model-hub"
    },
    "bugs": {
        "url": "https://github.com/qinfeng365/koishi-plugin-chatluna-adapter/issues"
    },
    "main": "lib/index.cjs",
    "module": "lib/index.mjs",
    "typings": "lib/index.d.ts",
    "files": [
        "lib",
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.mjs",
            "require": "./lib/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "type": "module",
    "license": "AGPL-3.0",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "atsc -b"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "chatbot",
        "koishi",
        "plugin",
        "chatluna",
        "adapter",
        "openai-compatible",
        "model-provider",
        "console"
    ],
    "dependencies": {
        "@chatluna/v1-shared-adapter": "^1.0.43",
        "@koishijs/plugin-console": "^5.30.11",
        "@langchain/core": "^0.3.80",
        "zod": "3.25.76",
        "zod-to-json-schema": "^3.24.6"
    },
    "devDependencies": {
        "@koishijs/client": "^5.30.11",
        "atsc": "^2.1.0",
        "koishi": "^4.18.9",
        "koishi-plugin-chatluna": "^1.4.0-alpha.32",
        "koishi-plugin-chatluna-storage-service": "^1.0.6",
        "typescript": "^5.9.2"
    },
    "peerDependencies": {
        "@koishijs/plugin-console": "^5.30.11",
        "koishi": "^4.18.9",
        "koishi-plugin-chatluna": "^1.4.0-alpha.32",
        "koishi-plugin-chatluna-storage-service": "^1.0.6"
    },
    "peerDependenciesMeta": {
        "koishi-plugin-chatluna-storage-service": {
            "optional": true
        }
    },
    "koishi": {
        "description": {
            "zh": "ChatLuna 多模型供应商聚合适配器，带独立 WebUI",
            "en": "Multi-provider model hub adapter for ChatLuna with an independent Web UI"
        },
        "service": {
            "required": [
                "chatluna"
            ],
            "optional": [
                "console",
                "chatluna_storage"
            ]
        }
    }
}
